# =============================================================
# ClimateTwin AI — Environment Configuration
# =============================================================
# Copy this file to `.env` and fill in real values for your
# target environment.  NEVER commit `.env` to version control.
# =============================================================

# ── Application ─────────────────────────────────────────────
APP_NAME="ClimateTwin AI"
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development          # development | staging | production

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=climatetwin
POSTGRES_PASSWORD=climatetwin
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=climatetwin_db

# ── SQLAlchemy ──────────────────────────────────────────────
DB_ECHO_LOG=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Security ────────────────────────────────────────────────
SECRET_KEY=CHANGE-ME-IN-PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── AI / ML ─────────────────────────────────────────────────
AI_MODEL_PATH=models/
AI_INFERENCE_TIMEOUT=60
